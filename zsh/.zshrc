export ZDOTDIR=$HOME/.config/zsh
source "$HOME/.config/zsh/.zshrc"

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/blackflame/Downloads/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/blackflame/Downloads/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/blackflame/Downloads/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/blackflame/Downloads/google-cloud-sdk/completion.zsh.inc'; fi
