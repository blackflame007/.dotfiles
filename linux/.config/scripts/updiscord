#!/bin/bash

# Define the directory where the PKGBUILD is located
pkgbuild_dir="$HOME/pkgbuild/discord"

# Change to the PKGBUILD directory
cd "$pkgbuild_dir" || { echo "Failed to change directory to $pkgbuild_dir. Exiting."; exit 1; }

# Fetch headers and extract the 'Location' header value
url=$(curl -sI "https://discord.com/api/download?platform=linux&format=tar.gz" | grep -i location | tr -d '\r') || { echo "Failed to fetch URL. Exiting."; exit 1; }

# Use sed to extract the version part from the URL
new_version=$(echo "$url" | sed -n 's/.*discord-\(.*\).tar.gz/\1/p')
if [ -z "$new_version" ]; then
    echo "Failed to extract new version. Exiting."
    exit 1
fi

echo "New Discord version detected: $new_version"

# Backup the original PKGBUILD
cp "PKGBUILD" "PKGBUILD.backup" || { echo "Failed to backup PKGBUILD. Exiting."; exit 1; }

# Update the PKGBUILD with the new version
sed -i "s/pkgver=.*/pkgver=$new_version/" PKGBUILD || { echo "Failed to update PKGBUILD. Exiting."; exit 1; }

echo "Updated PKGBUILD to version $new_version"

# Update package sums
if ! updpkgsums; then
    echo "Failed to update package sums. Exiting."
    exit 1
fi

# Clean up old package files before building
echo "Cleaning up old package files..."
find . -type f -name "*.pkg.tar.zst" -delete

# Build the package without installing
echo "Building Discord package version $new_version..."
if ! makepkg -s; then
    echo "Failed to build the package. Exiting."
    exit 1
fi

# Find the newly built package by looking for files created after the build started
# and matching the expected naming pattern
echo "Looking for newly built package..."
new_package=$(find . -type f -name "discord-${new_version}-*.pkg.tar.zst" -newer PKGBUILD | head -n 1)

if [ -z "$new_package" ]; then
    echo "New package not found. Trying alternative detection method..."
    # Fallback: look for the most recently modified package file
    new_package=$(find . -type f -name "*.pkg.tar.zst" -printf '%T@ %p\n' | sort -n | tail -n 1 | cut -d' ' -f2-)
fi

if [ -f "$new_package" ]; then
    echo "Installing package: $new_package"
    sudo pacman -U "$new_package" --noconfirm || { echo "Failed to install the package. Exiting."; exit 1; }
else
    echo "New package file not found. Exiting."
    echo "Available package files:"
    ls -la *.pkg.tar.zst 2>/dev/null || echo "No package files found"
    exit 1
fi

# Clean up old .zst and .gz files, keeping only the newly installed package
echo "Cleaning up old package files..."
find . -type f \( -name '*.zst' -o -name '*.gz' \) -not -name "$(basename "$new_package")" -delete

echo "Package updated, built, and installed successfully."
echo "Installed Discord version: $new_version"

